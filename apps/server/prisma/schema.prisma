generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  OWNER
  ADMIN
  EDITOR
}

enum GrenadeSide {
  T
  CT
  BOTH
}

enum GrenadeType {
  SMOKE
  FLASH
  MOLOTOV
  HE
}

enum GrenadeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum MediaType {
  IMAGE
  VIDEO
  EXTERNAL
}

model AdminUser {
  id         String    @id @default(cuid())
  telegramId String   @unique
  username   String?
  firstName  String?
  role       AdminRole @default(EDITOR)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model CsMap {
  id               String           @id @default(cuid())
  slug             String           @unique
  name             String
  active           Boolean          @default(true)
  sortOrder        Int              @default(0)
  overviewImageUrl String?
  emoji            String?
  premiumEmojiId   String?
  buttonStyle      String           @default("default")
  lineups          GrenadeLineup[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model GrenadeLineup {
  id           String             @id @default(cuid())
  mapId        String
  map          CsMap              @relation(fields: [mapId], references: [id], onDelete: Cascade)
  side         GrenadeSide
  grenadeType  GrenadeType
  area         String             @default("")
  areaSlug     String             @default("")
  positionSlug String             @default("")
  fromPosition String
  toPosition   String
  title        String
  description  String
  difficulty   GrenadeDifficulty  @default(EASY)
  tags         String[]           @default([])
  mediaType    MediaType
  mediaUrl     String
  thumbnailUrl String?
  mediaItems   Json?
  published    Boolean            @default(false)
  favorites    BotUserFavoriteLineup[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([mapId, published])
  @@index([grenadeType, side])
  @@index([mapId, side, areaSlug])
  @@index([mapId, side, areaSlug, grenadeType])
}

model BotUser {
  id                  String                  @id @default(cuid())
  telegramId          String                  @unique
  username            String?
  firstName           String?
  faceitPlayerId      String?
  faceitNickname      String?
  lastElo             Int?
  boundFaceitPlayerId String?
  boundFaceitNickname String?
  boundFaceitElo      Int?
  boundAt             DateTime?
  requests            Int                     @default(0)
  favorites           BotUserFavoriteLineup[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  lastSeenAt          DateTime                @default(now())
}

model BotUserFavoriteLineup {
  id        String         @id @default(cuid())
  userId    String
  user      BotUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineupId  String
  lineup    GrenadeLineup  @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([userId, lineupId])
  @@index([lineupId])
}

model PlayerQueryLog {
  id             String   @id @default(cuid())
  telegramId     String?
  query          String
  faceitPlayerId String?
  faceitNickname String?
  status         String
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([faceitPlayerId])
}

model BotEvent {
  id         String   @id @default(cuid())
  telegramId String?
  type       String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([type, createdAt])
  @@index([telegramId, createdAt])
}

model BroadcastCampaign {
  id            String              @id @default(cuid())
  title         String
  mediaType     String?
  mediaUrl      String?
  caption       String              @default("")
  buttons       Json?
  targetSegment String              @default("all")
  status        String              @default("draft")
  totalCount    Int                 @default(0)
  sentCount     Int                 @default(0)
  failedCount   Int                 @default(0)
  createdBy     String?
  sentAt        DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deliveries    BroadcastDelivery[]

  @@index([status, createdAt])
  @@index([createdAt])
}

model BroadcastDelivery {
  id          String            @id @default(cuid())
  campaignId  String
  campaign    BroadcastCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  telegramId  String
  status      String            @default("pending")
  error       String?
  sentAt      DateTime?
  createdAt   DateTime          @default(now())

  @@unique([campaignId, telegramId])
  @@index([telegramId])
  @@index([status])
}

model BotSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
