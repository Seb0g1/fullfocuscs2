{
  "name": "fullfocus-cs2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "corepack pnpm --filter @fullfocus/shared build && corepack pnpm --filter @fullfocus/card-renderer build && corepack pnpm --parallel --filter @fullfocus/server --filter @fullfocus/admin dev",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "corepack pnpm -r test",
    "lint": "corepack pnpm -r lint",
    "prisma:generate": "corepack pnpm --filter @fullfocus/server prisma:generate"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
